---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = Array.from(new Set(allPosts.flatMap((post) => post.data.tags))).sort();

  return tags.map((tag) => ({
    params: { tag: encodeURIComponent(tag) },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'blog'>[];
}

const { tag, posts } = Astro.props;
const tagHref = (value: string) => `/blog/tag/${encodeURIComponent(value)}`;
---

<Layout title={`#${tag} | Lei 的博客`} description={`Lei 的博客中带有 ${tag} 标签的文章`}>
  <Header />
  <main class="blog-page">
    <section class="blog-hero section">
      <div class="container">
        <div class="blog-hero-content fade-up">
          <a class="back-link" href="/blog">返回全部博客</a>
          <h1 class="blog-title">#{tag}</h1>
          <p class="blog-subtitle">
            {posts.length} 篇相关记录
          </p>
        </div>
      </div>
    </section>

    <section class="blog-list section">
      <div class="container">
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card card-3d fade-up">
              {post.data.image && (
                <a href={`/blog/${post.slug}`} class="blog-card-image">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    loading="lazy"
                  />
                </a>
              )}
              <div class="blog-card-content">
                <a href={`/blog/${post.slug}`} class="blog-card-link">
                  <time class="blog-card-date" datetime={post.data.pubDate.toISOString()}>
                    {new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <h2 class="blog-card-title">{post.data.title}</h2>
                  <p class="blog-card-desc">{post.data.description}</p>
                </a>
                {post.data.tags.length > 0 && (
                  <div class="blog-card-tags">
                    {post.data.tags.map((item) => (
                      <a
                        href={tagHref(item)}
                        class:list={['blog-tag', { active: item === tag }]}
                        aria-label={`查看 ${item} 标签文章`}
                      >
                        {item}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-page {
    min-height: 100vh;
    padding-top: 5rem;
  }

  .blog-hero {
    text-align: center;
    padding-bottom: 3rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    margin-bottom: 1rem;
    color: var(--accent-cyan);
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-title {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-bottom: 1rem;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-list {
    padding-top: 2rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: all var(--transition-slow);
    cursor: pointer;
  }

  .blog-card:hover {
    transform: translateY(-8px) rotateX(2deg);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
  }

  .blog-card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-tertiary);
    position: relative;
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  .blog-card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .blog-card-date {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .blog-card-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0;
  }

  .blog-card-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .blog-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    background: rgba(99, 102, 241, 0.15);
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 1rem;
    color: var(--accent-primary);
    font-weight: 500;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .blog-tag:hover,
  .blog-tag.active {
    background: rgba(99, 102, 241, 0.24);
    border-color: rgba(99, 102, 241, 0.55);
    color: var(--accent-cyan);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .blog-hero {
      padding-bottom: 2rem;
    }
  }
</style>
