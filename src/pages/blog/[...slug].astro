---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => 
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const nextPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const tagHref = (tag: string) => `/blog/tag/${encodeURIComponent(tag)}`;
---

<Layout 
  title={`${post.data.title} | Lei 的博客`} 
  description={post.data.description}
>
  <Header />
  <main class="blog-post-page">
    <article class="blog-post section">
      <div class="container">
        <header class="blog-post-header fade-up">
          <div class="blog-post-meta">
            <time class="blog-post-date" datetime={post.data.pubDate.toISOString()}>
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.data.updatedDate && (
              <time class="blog-post-updated" datetime={post.data.updatedDate.toISOString()}>
                更新于 {new Date(post.data.updatedDate).toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            )}
            <span class="blog-post-author">作者：{post.data.author}</span>
          </div>
          
          <h1 class="blog-post-title">{post.data.title}</h1>
          
          {post.data.description && (
            <p class="blog-post-description">{post.data.description}</p>
          )}
          
          {post.data.tags.length > 0 && (
            <div class="blog-post-tags">
              {post.data.tags.map((tag) => (
                <a href={tagHref(tag)} class="blog-tag">{tag}</a>
              ))}
            </div>
          )}
        </header>

        <div class="blog-post-content">
          <Content />
        </div>

        <nav class="blog-post-nav fade-up stagger-2">
          {prevPost ? (
            <a href={`/blog/${prevPost.slug}`} class="blog-nav-link blog-nav-prev">
              <span class="blog-nav-label">上一篇</span>
              <span class="blog-nav-title">{prevPost.data.title}</span>
            </a>
          ) : (
            <div></div>
          )}
          
          <a href="/blog" class="blog-nav-home">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </a>
          
          {nextPost ? (
            <a href={`/blog/${nextPost.slug}`} class="blog-nav-link blog-nav-next">
              <span class="blog-nav-label">下一篇</span>
              <span class="blog-nav-title">{nextPost.data.title}</span>
            </a>
          ) : (
            <div></div>
          )}
        </nav>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .blog-post-page {
    min-height: 100vh;
    padding-top: 5rem;
  }

  .blog-post {
    max-width: 800px;
    margin: 0 auto;
  }

  .blog-post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .blog-post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .blog-post-date,
  .blog-post-updated,
  .blog-post-author {
    display: inline-block;
  }

  .blog-post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .blog-post-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .blog-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .blog-post-content {
    margin-bottom: 4rem;
  }

  /* Markdown content styles */
  .blog-post-content :global(h1),
  .blog-post-content :global(h2),
  .blog-post-content :global(h3),
  .blog-post-content :global(h4) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .blog-post-content :global(h1) {
    font-size: 2rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .blog-post-content :global(h2) {
    font-size: 1.75rem;
  }

  .blog-post-content :global(h3) {
    font-size: 1.5rem;
  }

  .blog-post-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
    color: var(--text-secondary);
  }

  .blog-post-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.8;
  }

  .blog-post-content :global(blockquote) {
    border-left: 4px solid var(--accent-primary);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .blog-post-content :global(code) {
    background: var(--bg-tertiary);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--accent-cyan);
  }

  .blog-post-content :global(pre) {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .blog-post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text-primary);
  }

  .blog-post-content :global(a) {
    color: var(--accent-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .blog-post-content :global(a:hover) {
    color: var(--accent-primary);
  }

  .blog-post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 2rem 0;
  }

  .blog-post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 2rem 0;
  }

  .blog-post-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: center;
    padding-top: 3rem;
    border-top: 1px solid var(--border-color);
  }

  .blog-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 0.75rem;
    transition: all var(--transition-normal);
    text-decoration: none;
    color: inherit;
  }

  .blog-nav-link:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-primary);
    transform: translateX(var(--nav-translate, 0));
  }

  .blog-nav-prev {
    --nav-translate: -4px;
  }

  .blog-nav-next {
    --nav-translate: 4px;
    text-align: right;
  }

  .blog-nav-label {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-family: var(--font-mono);
  }

  .blog-nav-title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .blog-nav-home {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 50%;
    color: var(--text-secondary);
    transition: all var(--transition-normal);
    text-decoration: none;
  }

  .blog-nav-home:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-primary);
    color: var(--accent-primary);
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .blog-post-nav {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .blog-nav-next {
      text-align: left;
    }
  }
</style>
