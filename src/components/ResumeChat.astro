  const fallbacks = [
    '这个问题适合直接聊。你可以邮件 `827919619@qq.com` 或微信 `N-429228` 找我。\n\n也可以换个角度问：项目、技术栈、工作经历、怎么联系。',
    '我目前整理得比较完整的是：**我是谁 / Cairn / Lumen Brief / MCPort / 技术栈 / 项目 / 联系方式**。',
    '这块我还没有展开。你可以先问 Cairn、Lumen Brief、MCPort，或者直接看项目卡片里的 GitHub 链接。'
  ];

  function matchIntent(text: string): Intent | null {
    const normalized = text.toLowerCase().trim();
    for (const intent of intents) {
      if (intent.keys.some((k) => k.test(normalized))) {
        return intent;
      }
    }
    return null;
  }

  function pickFallback() {
    return fallbacks[Math.floor(Math.random() * fallbacks.length)];
  }

  // === DOM helpers ===
  const root = document.getElementById('resume-chat') as HTMLDivElement | null;
  const body = document.getElementById('resume-chat-body') as HTMLDivElement | null;
  const form = document.getElementById('resume-chat-form') as HTMLFormElement | null;
  const input = document.getElementById('resume-chat-input') as HTMLInputElement | null;
  const suggestionsBar = document.getElementById('resume-chat-suggestions') as HTMLDivElement | null;
  const greetingNode = document.getElementById('resume-chat-greeting') as HTMLScriptElement | null;

  function readGreeting() {
    if (!greetingNode?.textContent) return '';
    try {
      return JSON.parse(greetingNode.textContent) as string;
    } catch {
      return greetingNode.textContent;
    }
  }

  if (!root || !body || !form || !input || !suggestionsBar) {
    console.warn('[ResumeChat] missing elements');
  }

  let isStreaming = false;
  let hasGreeted = false;

  function open() {
    if (!root) return;
    root.hidden = false;
    root.setAttribute('aria-hidden', 'false');
    // double rAF so the `hidden` removal flushes before the transition kicks in
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        root.setAttribute('data-open', 'true');
      });
    });
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 200);
    if (!hasGreeted) {
      hasGreeted = true;
      streamAssistant(readGreeting());
    }
  }

  function close() {
    if (!root) return;
    root.removeAttribute('data-open');
    document.body.style.overflow = '';
    setTimeout(() => {
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
    }, 350);
  }

  function scrollToBottom() {
    if (!body) return;
    body.scrollTo({ top: body.scrollHeight, behavior: 'smooth' });
  }

  // Minimal markdown-ish formatting for bubbles (bold, inline code, [[link]])
  function renderInline(text: string): string {
    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return escape(text)
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/`([^`]+)`/g, '<code>$1</code>')
      .replace(/\[\[([^\]]+)\]\]/g, '<strong>$1</strong>');
  }

  function appendUserMessage(text: string) {
    if (!body) return;
    const wrap = document.createElement('div');
    wrap.className = 'message user';
    wrap.innerHTML = `<div class="msg-bubble">${renderInline(text)}</div>`;
    body.appendChild(wrap);
    scrollToBottom();
  }

  function appendAssistantSkeleton(): { bubble: HTMLDivElement; wrap: HTMLDivElement } {
    const wrap = document.createElement('div');
    wrap.className = 'message ai';
    wrap.innerHTML = `
      <div class="msg-avatar">L</div>
      <div class="msg-bubble streaming"></div>
    `;
    body!.appendChild(wrap);
    const bubble = wrap.querySelector('.msg-bubble') as HTMLDivElement;
    return { bubble, wrap };
  }

  function appendTyping(): HTMLDivElement {
    const wrap = document.createElement('div');
    wrap.className = 'message ai';
    wrap.innerHTML = `
      <div class="msg-avatar">L</div>
      <div class="msg-bubble"><span class="typing-dots"><span></span><span></span><span></span></span></div>
    `;
    body!.appendChild(wrap);
    scrollToBottom();
    return wrap;
  }

  async function sleep(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  function setSuggestions(list: string[]) {
    if (!suggestionsBar) return;
    suggestionsBar.innerHTML = '';
    list.forEach((s) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'suggestion-chip';
      btn.dataset.suggestion = s;
      btn.textContent = s;
      suggestionsBar.appendChild(btn);
    });
  }

  async function streamText(target: HTMLDivElement, fullText: string) {
    const rendered = renderInline(fullText);
    // We stream the *plain* text char by char, then on completion swap to
    // the markdown-rendered HTML so bold/code/links light up.
    let i = 0;
    const chars = [...fullText];
    while (i < chars.length) {
      // Slight burst pattern: type 1-3 chars per tick for a natural cadence
      const step = chars[i] === '\n' ? 1 : 1 + Math.floor(Math.random() * 2);
      target.textContent = chars.slice(0, i + step).join('');
      i += step;
      scrollToBottom();
      const ch = chars[i - 1];
      let delay = 14 + Math.random() * 22;
      if (ch === '。' || ch === '\n' || ch === '.') delay += 80;
      else if (ch === '，' || ch === ',' || ch === '·') delay += 30;
      await sleep(delay);
    }
    target.innerHTML = rendered;
    target.classList.remove('streaming');
    scrollToBottom();
  }

  async function streamAssistant(text: string, followups?: string[]) {
    if (!body) return;
    isStreaming = true;
    // Show typing dots briefly first
    const typingWrap = appendTyping();
    await sleep(420 + Math.random() * 380);
    typingWrap.remove();

    const { bubble } = appendAssistantSkeleton();
    scrollToBottom();
    await streamText(bubble, text);

    if (followups && followups.length) setSuggestions(followups);
    isStreaming = false;
  }

  async function handleUserInput(text: string) {
    const trimmed = text.trim();
    if (!trimmed || isStreaming) return;
    appendUserMessage(trimmed);
    input!.value = '';

    const intent = matchIntent(trimmed);
    const answer = intent ? (typeof intent.answer === 'function' ? intent.answer() : intent.answer) : pickFallback();
    const followups = intent?.followups;
    await streamAssistant(answer, followups);
  }

  // === Event wiring ===
  function isTriggerElement(el: EventTarget | null): el is HTMLElement {
    if (!(el instanceof HTMLElement)) return false;
    if (el.hasAttribute('data-resume-chat')) return true;
    const anchor = el.closest('a');
    if (anchor && (anchor.getAttribute('href') === '#resume-chat' || anchor.hasAttribute('data-resume-chat'))) return true;
    return el.closest('[data-resume-chat]') !== null;
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target) return;

    // Open
    if (isTriggerElement(target)) {
      e.preventDefault();
      open();
      return;
    }

    // Close
    if (target.closest('[data-resume-chat-close]')) {
      close();
      return;
    }

    // Footer action → contact intent
    const actionEl = target.closest('[data-resume-chat-action]') as HTMLElement | null;
    if (actionEl && actionEl.dataset.resumeChatAction === 'contact') {
      handleUserInput('怎么联系你？');
      return;
    }

    // Suggestion chip
    const chip = target.closest('.suggestion-chip') as HTMLButtonElement | null;
    if (chip && chip.dataset.suggestion) {
      handleUserInput(chip.dataset.suggestion);
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && root && root.getAttribute('data-open') === 'true') {
      close();
    }
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    handleUserInput(input!.value);
  });
</script>
