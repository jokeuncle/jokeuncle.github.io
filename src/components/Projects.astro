---
// Projects Component - Showcasing existing projects

const projects = [
  {
    title: '阿里盒马小镇2.0互动游戏',
    description: '大型互动游戏平台，支持多人在线、实时同步与丰富的游戏玩法',
    link: '#',
    icon: '🎮',
    tags: ['互动游戏', '实时同步', 'Canvas', 'WebSocket'],
    color: '#6366f1'
  },
  {
    title: '美团BFF搭建平台',
    description: '企业级 BFF（Backend for Frontend）搭建平台，提升前后端协作效率',
    link: '#',
    icon: '🏗️',
    tags: ['BFF', '微服务', 'Node.js', '企业级'],
    color: '#8b5cf6'
  },
  {
    title: '字节前端研发部署平台',
    description: '一站式前端研发与部署平台，支持 CI/CD、多环境管理与自动化发布',
    link: '#',
    icon: '🚀',
    tags: ['CI/CD', 'DevOps', '自动化', '部署'],
    color: '#22d3ee'
  },
  {
    title: '拼多多果园互动游戏',
    description: '高并发互动游戏系统，支持百万级用户同时在线，流畅的游戏体验',
    link: '#',
    icon: '🌳',
    tags: ['高并发', '性能优化', '互动', '游戏引擎'],
    color: '#ec4899'
  }
];
---

<section class="projects section" id="projects">
  <div class="container">
    <div class="section-header fade-up">
      <span class="section-tag">项目作品</span>
      <h2 class="section-title">
        <span class="gradient-text">精选项目</span>
      </h2>
      <p class="section-desc">
        探索我的创意项目与实验作品
      </p>
    </div>
    
    <div class="projects-grid">
      {projects.map((project, index) => (
        <a 
          href={project.link} 
          class={`project-card fade-up stagger-${index + 1}`}
          style={`--project-color: ${project.color}`}
        >
          <div class="project-icon">{project.icon}</div>
          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            <div class="project-tags">
              {project.tags.map(tag => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </div>
          <div class="project-glow"></div>
        </a>
      ))}
    </div>
    
    <div class="projects-cta fade-up">
      <p class="cta-text">想看看更多？</p>
      <a href="https://github.com/jokeuncle" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        访问 GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--bg-secondary);
    position: relative;
  }
  
  .projects::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .section-tag {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent-primary);
    margin-bottom: 1rem;
  }
  
  .section-title {
    margin-bottom: 1rem;
  }
  
  .section-desc {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  
  .project-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 1.25rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
  }
  
  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--project-color);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 30px color-mix(in srgb, var(--project-color) 15%, transparent);
  }
  
  .project-icon {
    width: 64px;
    height: 64px;
    background: color-mix(in srgb, var(--project-color) 10%, transparent);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
    transition: all var(--transition-normal);
  }
  
  .project-card:hover .project-icon {
    transform: scale(1.1) rotate(-5deg);
  }
  
  .project-content {
    flex: 1;
    min-width: 0;
  }
  
  .project-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  
  .project-desc {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .project-tag {
    padding: 0.25rem 0.625rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    transition: all var(--transition-fast);
  }
  
  .project-card:hover .project-tag {
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.08);
  }
  
  .project-arrow {
    color: var(--text-tertiary);
    transition: all var(--transition-normal);
    flex-shrink: 0;
  }
  
  .project-card:hover .project-arrow {
    color: var(--project-color);
    transform: translateX(4px);
  }
  
  .project-glow {
    position: absolute;
    top: -50%;
    right: -30%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, var(--project-color) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-normal);
    pointer-events: none;
    filter: blur(60px);
  }
  
  .project-card:hover .project-glow {
    opacity: 0.1;
  }
  
  .projects-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  .cta-text {
    color: var(--text-tertiary);
    font-size: 1rem;
  }
  
  @media (max-width: 968px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
  
  @media (max-width: 600px) {
    .project-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }
    
    .project-arrow {
      display: none;
    }
    
    .project-tags {
      justify-content: center;
    }
  }
</style>
