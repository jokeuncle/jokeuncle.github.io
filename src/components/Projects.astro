---
// Projects Component - Featured public projects + proof points
import BgText from '@/components/BgText.astro';

const mcpText =
  "MCP gives AI clients a small, typed way to call tools and read resources. RAG gives models a way to answer from real documents instead of memory. The projects here sit in that practical middle ground: turn messy files into searchable context, turn HTTP endpoints into MCP tools, turn daily reading into notes, and turn local AI sessions into visible desktop signals. The important part is not the vocabulary. The important part is whether the tool can be installed, run, checked, and improved over time.";

const featuredProjects = [
  {
    name: 'Cairn / DocsGraph',
    tagline: 'Local-first document graph for coding agents',
    taglineCn: '把文档整理成 Agent 能按需读取的上下文',
    description:
      '把 README、Markdown、PDF 等资料建成 Tree、Summary、Entity、XRef、Vector 多层索引，再通过 MCP 暴露给 Codex、Claude Code、Cursor 等客户端。目标很直接：少塞整篇文档，多拿刚好够用的上下文。',
    status: '已发布 alpha',
    statusType: 'production',
    link: 'https://github.com/jokeuncle/cairn',
    glyph: 'DG',
    tags: ['MCP', 'RAG', 'DocsGraph', 'PyPI'],
    color: '#6366f1',
    accent: '#22d3ee'
  },
  {
    name: 'Lumen Brief',
    tagline: 'Daily AI brief to local knowledge base',
    taglineCn: '把每天的信息源整理成能复用的笔记',
    description:
      '一个面向个人学习的自动化简报 CLI。它聚合 AI 研究、开源模型、工具和岗位趋势，输出卡片、HTML 预览、Obsidian 笔记、NotebookLM 资料包和每日归档。',
    status: '日常运行',
    statusType: 'building',
    link: 'https://github.com/jokeuncle/aibrief',
    glyph: 'LB',
    tags: ['CLI', 'Obsidian', 'NotebookLM', 'Automation'],
    color: '#22d3ee',
    accent: '#ec4899'
  },
  {
    name: 'MCPort',
    tagline: 'HTTP API to MCP tool bridge',
    taglineCn: '把已有 API 配成 AI 客户端能调用的工具',
    description:
      '一个 HTTP-to-MCP 管理服务。Web UI 里配置 endpoint、参数、鉴权和 OpenAPI 导入，运行时通过 /mcp 暴露为 typed tools，让旧接口更快进入工具调用工作流。',
    status: '构建中',
    statusType: 'exploring',
    link: 'https://github.com/jokeuncle/mcport',
    glyph: 'MP',
    tags: ['FastAPI', 'FastMCP', 'OpenAPI', 'Tool Calling'],
    color: '#8b5cf6',
    accent: '#ec4899'
  }
];

const workProjects = [
  {
    title: 'Sotto · 桌面上的每日观察',
    description: '基于 Tauri 的 macOS 小工具，调用本地 Claude/Codex CLI 生成每日短内容，并以低打扰窗口沉在桌面层。',
    metrics: [
      { label: '形态', value: '桌面应用' },
      { label: '发布', value: 'Cask/DMG' },
      { label: '重点', value: '低打扰' }
    ],
    link: 'https://github.com/jokeuncle/sotto',
    icon: 'SO',
    tags: ['Tauri', 'Rust', 'React', 'Local CLI'],
    color: '#6366f1'
  },
  {
    title: 'Red Green Light · AI 会话状态灯',
    description: '菜单栏交通灯应用，通过本地 hook server 接收编码会话事件，用 tray icon 和 SSE 页面显示 idle、working、waiting 状态。',
    metrics: [
      { label: '入口', value: '菜单栏' },
      { label: '通信', value: 'HTTP/SSE' },
      { label: '用途', value: '状态可见' }
    ],
    link: 'https://github.com/jokeuncle/red-green-light',
    icon: 'RG',
    tags: ['Tauri', 'Hooks', 'SSE', 'Tray App'],
    color: '#ec4899'
  },
  {
    title: 'Luma District · 3D 商业街区原型',
    description: 'React Three Fiber 做的 3D 商业街区原型，把铺位、商家、货架、营销位、购物车和 WebXR 入口放进同一个体验里。',
    metrics: [
      { label: '形态', value: '3D Web' },
      { label: '测试', value: '7 files' },
      { label: '方向', value: 'Commerce' }
    ],
    link: 'https://github.com/jokeuncle/luma-district',
    icon: 'LD',
    tags: ['Three.js', 'R3F', 'WebXR', 'Prototype'],
    color: '#8b5cf6'
  },
  {
    title: 'Shadow Curve Atlas · 曲线形态扫描',
    description: '从分时曲线中提取斜率、曲率、回撤、突破、修复率等特征，做形态聚类、候选复盘和实时相似度扫描。',
    metrics: [
      { label: '类型', value: '数据工具' },
      { label: '流程', value: '闭环复盘' },
      { label: '重点', value: '特征工程' }
    ],
    link: 'https://github.com/jokeuncle/shadow-curve-atlas',
    icon: 'SC',
    tags: ['Python', 'Pattern Mining', 'Scanner', 'Automation'],
    color: '#22d3ee'
  }
];
---

<section class="projects section" id="projects">
  <BgText text={mcpText} duration={11} opacity={0.55} fade={0.8} stripe={['rgba(139, 92, 246, 0.5)', 'rgba(99, 102, 241, 0.95)', 'rgba(34, 211, 238, 0.65)']} />
  <div class="container">
    <div class="section-header fade-up">
      <span class="section-tag">项目作品</span>
      <h2 class="section-title">
        <span class="gradient-text">正在打造</span>
      </h2>
      <p class="section-desc">
        这些是我近期认真做的东西。有些已经能用，有些还在长大，但它们都来自真实需求：文档怎么被读到、工具怎么被调用、信息怎么沉淀、桌面怎么少打扰。
      </p>
    </div>

    <div class="featured-grid">
      {featuredProjects.map((project, index) => (
        <a
          href={project.link}
          class={`featured-card fade-up stagger-${index + 1}`}
          style={`--project-color: ${project.color}; --project-accent: ${project.accent};`}
        >
          <div class="featured-header">
            <div class="featured-mark" aria-hidden="true">{project.glyph}</div>
            <div class="featured-title-wrap">
              <h3 class="featured-name">{project.name}</h3>
              <p class="featured-tagline">{project.tagline}</p>
              <p class="featured-tagline-cn">{project.taglineCn}</p>
            </div>
            <span class={`featured-status status-${project.statusType}`}>
              <span class="status-dot"></span>
              {project.status}
            </span>
          </div>

          <p class="featured-desc">{project.description}</p>

          <div class="featured-footer">
            <div class="featured-tags">
              {project.tags.map((tag) => (
                <span class="featured-tag">{tag}</span>
              ))}
            </div>
            <div class="featured-arrow" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </div>
          </div>

          <div class="featured-glow"></div>
          <div class="featured-border" aria-hidden="true"></div>
        </a>
      ))}
    </div>

    <div class="subsection-divider fade-up" aria-hidden="true">
      <span class="divider-line"></span>
      <span class="divider-label">更多作品 · More Work</span>
      <span class="divider-line"></span>
    </div>

    <div class="projects-grid">
      {workProjects.map((project, index) => (
        <a
          href={project.link}
          class={`project-card fade-up stagger-${index + 1}`}
          style={`--project-color: ${project.color}`}
        >
          <div class="project-icon">{project.icon}</div>
          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-desc">{project.description}</p>
            {project.metrics && (
              <div class="project-metrics">
                {project.metrics.map((m) => (
                  <span class="project-metric">
                    <span class="metric-value">{m.value}</span>
                    <span class="metric-label">{m.label}</span>
                  </span>
                ))}
              </div>
            )}
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>
          </div>
          <div class="project-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </div>
          <div class="project-glow"></div>
        </a>
      ))}
    </div>
    
    <div class="projects-cta fade-up">
      <p class="cta-text">想看看更多？</p>
      <a href="https://github.com/jokeuncle" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        访问 GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .projects {
    background: var(--bg-secondary);
    position: relative;
    isolation: isolate;
  }

  /* Keep BgText behind everything but above the section background */
  .projects > .container {
    position: relative;
    z-index: 1;
  }
  
  .projects::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .section-tag {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent-primary);
    margin-bottom: 1rem;
  }
  
  .section-title {
    margin-bottom: 1rem;
  }
  
  .section-desc {
    color: var(--text-secondary);
    font-size: 1.125rem;
    max-width: 500px;
    margin: 0 auto;
  }
  
  /* === Featured public projects === */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .featured-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 2rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--project-color) 6%, transparent), transparent 40%),
      var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 1.5rem;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.4s, box-shadow 0.4s;
    isolation: isolate;
  }

  .featured-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in srgb, var(--project-color) 60%, transparent);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.35),
      0 0 50px color-mix(in srgb, var(--project-color) 18%, transparent);
  }

  .featured-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: flex-start;
    gap: 1rem;
  }

  .featured-mark {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--project-color);
    background:
      linear-gradient(135deg,
        color-mix(in srgb, var(--project-color) 18%, transparent),
        color-mix(in srgb, var(--project-accent) 12%, transparent));
    border: 1px solid color-mix(in srgb, var(--project-color) 35%, transparent);
    flex-shrink: 0;
  }

  .featured-title-wrap {
    min-width: 0;
  }

  .featured-name {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }

  .featured-tagline {
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--text-secondary);
    margin: 0 0 0.2rem;
    max-width: none;
    font-weight: 500;
  }

  .featured-tagline-cn {
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--text-tertiary);
    margin: 0;
    max-width: none;
  }

  .featured-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 500;
    white-space: nowrap;
    background: color-mix(in srgb, var(--project-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--project-color) 30%, transparent);
    color: var(--project-color);
    flex-shrink: 0;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 8px currentColor;
    animation: status-pulse 2.4s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.45; transform: scale(0.85); }
  }

  .featured-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
    max-width: none;
  }

  .featured-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .featured-tag {
    padding: 0.25rem 0.6rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.4rem;
    font-size: 0.7rem;
    color: var(--text-tertiary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .featured-card:hover .featured-tag {
    color: var(--text-secondary);
    border-color: color-mix(in srgb, var(--project-color) 25%, transparent);
  }

  .featured-arrow {
    color: var(--text-tertiary);
    transition: transform var(--transition-normal), color var(--transition-normal);
    flex-shrink: 0;
  }

  .featured-card:hover .featured-arrow {
    color: var(--project-color);
    transform: translateX(4px);
  }

  .featured-glow {
    position: absolute;
    top: -40%;
    right: -30%;
    width: 70%;
    height: 180%;
    background: radial-gradient(ellipse, var(--project-accent) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
    filter: blur(80px);
    z-index: -1;
  }

  .featured-card:hover .featured-glow {
    opacity: 0.18;
  }

  /* Animated gradient border that lights up on hover */
  .featured-border {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg,
      transparent,
      color-mix(in srgb, var(--project-color) 60%, transparent),
      transparent,
      color-mix(in srgb, var(--project-accent) 60%, transparent),
      transparent);
    background-size: 300% 300%;
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.5s;
    pointer-events: none;
    animation: border-flow 6s linear infinite;
  }

  .featured-card:hover .featured-border {
    opacity: 1;
  }

  @keyframes border-flow {
    0% { background-position: 0% 50%; }
    100% { background-position: 300% 50%; }
  }

  /* === Subsection divider between featured and past work === */
  .subsection-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 0 auto 2.5rem;
    max-width: 600px;
    color: var(--text-tertiary);
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  }

  .divider-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* === Past work grid (existing compact cards) === */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  
  .project-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 1.25rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-decoration: none;
  }
  
  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--project-color);
    box-shadow: 
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 30px color-mix(in srgb, var(--project-color) 15%, transparent);
  }
  
  .project-icon {
    width: 64px;
    height: 64px;
    background: color-mix(in srgb, var(--project-color) 10%, transparent);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--project-color);
    flex-shrink: 0;
    transition: all var(--transition-normal);
  }
  
  .project-card:hover .project-icon {
    transform: scale(1.1) rotate(-5deg);
  }
  
  .project-content {
    flex: 1;
    min-width: 0;
  }
  
  .project-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  
  .project-desc {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .project-metrics {
    display: flex;
    gap: 1.2rem;
    margin: 0.4rem 0 0.85rem;
    padding: 0.65rem 0.8rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    flex-wrap: wrap;
  }

  .project-metric {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }

  .metric-value {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--project-color);
    line-height: 1.2;
  }

  .metric-label {
    font-size: 0.68rem;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
  }
  
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .project-tag {
    padding: 0.25rem 0.625rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-tertiary);
    transition: all var(--transition-fast);
  }
  
  .project-card:hover .project-tag {
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.08);
  }
  
  .project-arrow {
    color: var(--text-tertiary);
    transition: all var(--transition-normal);
    flex-shrink: 0;
  }
  
  .project-card:hover .project-arrow {
    color: var(--project-color);
    transform: translateX(4px);
  }
  
  .project-glow {
    position: absolute;
    top: -50%;
    right: -30%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, var(--project-color) 0%, transparent 60%);
    opacity: 0;
    transition: opacity var(--transition-normal);
    pointer-events: none;
    filter: blur(60px);
  }
  
  .project-card:hover .project-glow {
    opacity: 0.1;
  }
  
  .projects-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  
  .cta-text {
    color: var(--text-tertiary);
    font-size: 1rem;
  }
  
  @media (max-width: 968px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .featured-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .project-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }

    .project-arrow {
      display: none;
