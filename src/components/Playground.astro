---
// Playground - an interactive terminal-style demo of public AI tools.
// It mocks several commands so visitors can feel the workflow.
---

<section class="playground section" id="playground" aria-label="AI toolchain playground">
  <div class="container">
    <div class="section-header fade-up">
      <span class="section-tag">Playground · 摸一下</span>
      <h2 class="section-title">
        <span class="gradient-text">在终端里感受</span>
        <span class="title-cn">作品怎么跑</span>
      </h2>
      <p class="section-desc">
        我把几个公开项目压成了终端演示：索引文档、暴露工具、整理资料、导入 API。真实代码和发布记录都在项目卡片里。
      </p>
    </div>

    <div class="terminal fade-up stagger-1">
      <div class="terminal-bar">
        <div class="bar-dots">
          <span></span><span></span><span></span>
        </div>
        <span class="bar-title">jokeuncle-tools · interactive demo</span>
        <span class="bar-status">
          <span class="status-led"></span>
          mock mode
        </span>
      </div>

      <div class="terminal-body" id="playground-body" aria-live="polite">
        <div class="line line-comment"># 点几个命令，看看这些公开项目大概解决什么问题</div>
        <div class="line line-comment"># —— 点击右侧或下方的命令运行</div>
        <div class="line line-prompt"><span class="prompt-prefix">~/jokeuncle</span> <span class="prompt-arrow">›</span> <span class="prompt-cursor">▍</span></div>
      </div>

      <div class="terminal-chips" id="playground-chips">
        <button type="button" class="cmd-chip" data-cmd="docsgraph init --repo .">
          <span class="chip-key">$</span> docsgraph init --repo .
        </button>
        <button type="button" class="cmd-chip" data-cmd="docsgraph serve --mcp">
          <span class="chip-key">$</span> docsgraph serve --mcp
        </button>
        <button type="button" class="cmd-chip" data-cmd="yo brief --today --notebooklm">
          <span class="chip-key">$</span> yo brief --today --notebooklm
        </button>
        <button type="button" class="cmd-chip" data-cmd="mcport import openapi.yaml">
          <span class="chip-key">$</span> mcport import openapi.yaml
        </button>
        <button type="button" class="cmd-chip cmd-chip-secondary" data-cmd="__clear">
          <span class="chip-key">⌫</span> clear
        </button>
      </div>
    </div>

    <p class="playground-note fade-up">
      <span>这里展示的是流程和输出形态。要看真实实现，可以从项目卡片进入 GitHub。</span>
    </p>
  </div>
</section>

<style>
  .playground {
    position: relative;
    overflow: hidden;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    display: inline-block;
    padding: 0.375rem 1rem;
    background: rgba(34, 211, 238, 0.08);
    border: 1px solid rgba(34, 211, 238, 0.22);
    border-radius: 2rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.82rem;
    color: var(--accent-cyan);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .section-title {
    margin-bottom: 1rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .title-cn {
    color: var(--text-tertiary);
    font-size: 0.7em;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-weight: 500;
  }

  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* === Terminal === */
  .terminal {
    max-width: 920px;
    margin: 0 auto;
    background:
      linear-gradient(180deg, rgba(15, 17, 26, 0.96), rgba(10, 11, 18, 0.98));
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.5),
      0 0 50px rgba(99, 102, 241, 0.12);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.1rem;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .bar-dots {
    display: flex;
    gap: 6px;
  }

  .bar-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .bar-dots span:nth-child(1) { background: #ff5f57; }
  .bar-dots span:nth-child(2) { background: #febc2e; }
  .bar-dots span:nth-child(3) { background: #28c840; }

  .bar-title {
    flex: 1;
    text-align: center;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    color: var(--text-tertiary);
    letter-spacing: 0.02em;
  }

  .bar-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.18rem 0.6rem;
    background: rgba(34, 211, 238, 0.08);
    border: 1px solid rgba(34, 211, 238, 0.22);
    border-radius: 999px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.65rem;
    color: var(--accent-cyan);
    letter-spacing: 0.04em;
  }

  .status-led {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-cyan);
    box-shadow: 0 0 6px var(--accent-cyan);
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .terminal-body {
    padding: 1.2rem 1.4rem;
    min-height: 320px;
    max-height: 520px;
    overflow-y: auto;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--text-secondary);
    scroll-behavior: smooth;
  }

  .terminal-body::-webkit-scrollbar {
    width: 6px;
  }
  .terminal-body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
  }

  .line {
    white-space: pre-wrap;
    word-break: break-word;
  }

  .line + .line {
    margin-top: 0.15rem;
  }

  .line-comment {
    color: var(--text-tertiary);
    opacity: 0.7;
  }

  .line-prompt {
    color: var(--text-primary);
  }

  .prompt-prefix {
    color: #67e8f9;
  }

  .prompt-arrow {
    color: var(--accent-primary);
    margin: 0 0.4rem;
  }

  .prompt-cursor {
    display: inline-block;
    color: var(--accent-cyan);
    animation: cursor-blink 0.9s step-end infinite;
  }

  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  .line-output {
    color: var(--text-secondary);
  }

  .line-success { color: #34d399; }
  .line-info    { color: #67e8f9; }
  .line-warn    { color: #fbbf24; }
  .line-error   { color: #f87171; }
  .line-key     { color: var(--accent-primary); }
  .line-value   { color: var(--text-primary); }
  .line-dim     { color: var(--text-tertiary); opacity: 0.8; }

  .progress-bar {
    display: inline-block;
    color: #22d3ee;
    letter-spacing: -1px;
  }

  /* === Chips === */
  .terminal-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.85rem 1.1rem 1rem;
    background: rgba(0, 0, 0, 0.25);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .cmd-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.85rem;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.22);
    border-radius: 8px;
    color: var(--text-secondary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .cmd-chip:hover {
    background: rgba(99, 102, 241, 0.18);
    border-color: var(--accent-primary);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .cmd-chip:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  .cmd-chip-secondary {
    background: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.1);
    margin-left: auto;
  }

  .chip-key {
    color: var(--accent-cyan);
    font-weight: 600;
  }

  /* === Footer note === */
  .playground-note {
    text-align: center;
    margin: 2rem auto 0;
    max-width: 720px;
    color: var(--text-tertiary);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .playground-note strong {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .playground-note a {
    color: var(--accent-cyan);
    text-decoration: underline;
    text-decoration-color: rgba(34, 211, 238, 0.4);
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .terminal-body {
      font-size: 0.78rem;
      padding: 1rem;
    }
    .cmd-chip {
      font-size: 0.72rem;
      padding: 0.35rem 0.7rem;
    }
    .cmd-chip-secondary {
      margin-left: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-led,
    .prompt-cursor {
      animation: none;
    }
  }
</style>

<script>
  type Line = { text: string; cls?: string };

  const responses: Record<string, Line[]> = {
    'docsgraph init --repo .': [
      { text: 'Scanning repository docs ...', cls: 'line-dim' },
      { text: '  README.md                 parsed', cls: 'line-success' },
      { text: '  docs/*.md                 parsed', cls: 'line-success' },
      { text: '  papers/*.pdf              text extracted', cls: 'line-success' },
      { text: '' },
      { text: 'Index layers', cls: 'line-key' },
      { text: '  tree      sections and headings', cls: 'line-value' },
      { text: '  summary   gist and synopsis', cls: 'line-value' },
      { text: '  entities  terms, code names, proper names', cls: 'line-value' },
      { text: '  xref      links and mentions', cls: 'line-value' },
      { text: '  vector    semantic search chunks', cls: 'line-value' },
      { text: '' },
      { text: 'done: .cairn/index is ready for local agent clients', cls: 'line-success' }
    ],
    'docsgraph serve --mcp': [
      { text: 'Starting DocsGraph MCP server ...', cls: 'line-info' },
      { text: 'transport: stdio', cls: 'line-dim' },
      { text: '' },
      { text: 'tools exposed', cls: 'line-key' },
      { text: '  list_documents     list indexed docs', cls: 'line-value' },
      { text: '  search_documents   ranked section search', cls: 'line-value' },
      { text: '  repo_context       compact context pack', cls: 'line-value' },
      { text: '  repo_graph         docs relationship map', cls: 'line-value' },
      { text: '  repo_impact        affected docs surface', cls: 'line-value' },
      { text: '' },
      { text: 'ready: connect from Codex, Claude Code, Cursor, Goose, or any MCP client', cls: 'line-success' }
    ],
    'yo brief --today --notebooklm': [
      { text: 'Collecting sources ...', cls: 'line-info' },
      { text: '  labs blogs, arXiv, GitHub trending, HN, LocalLLaMA', cls: 'line-dim' },
      { text: 'Ranking high-signal items ...', cls: 'line-info' },
      { text: 'Writing outputs ...', cls: 'line-info' },
      { text: '' },
      { text: '  card.md              daily push card', cls: 'line-success' },
      { text: '  preview.html          readable browser view', cls: 'line-success' },
      { text: '  obsidian/*.md         long-term notes', cls: 'line-success' },
      { text: '  notebooklm-pack/      source bundle', cls: 'line-success' },
      { text: '' },
      { text: 'done: today brief archived and ready to review', cls: 'line-success' }
    ],
    'mcport import openapi.yaml': [
      { text: 'Reading OpenAPI document ...', cls: 'line-info' },
      { text: '  14 paths · 37 operations', cls: 'line-dim' },
      { text: 'Creating endpoint drafts ...', cls: 'line-info' },
      { text: '' },
      { text: 'mapped tools', cls: 'line-key' },
      { text: '  get_user_profile      GET /users/{id}', cls: 'line-value' },
      { text: '  search_documents      POST /search', cls: 'line-value' },
      { text: '  create_ticket         POST /tickets', cls: 'line-value' },
      { text: '' },
      { text: 'next: review auth profile, test calls, then enable /mcp runtime', cls: 'line-warn' }
    ]
  };

  const body = document.getElementById('playground-body') as HTMLDivElement | null;
  const chips = document.getElementById('playground-chips') as HTMLDivElement | null;
  if (!body || !chips) {
    console.warn('[Playground] missing elements');
  }

  let isRunning = false;

  function sleep(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  function setChipsDisabled(disabled: boolean) {
    chips?.querySelectorAll<HTMLButtonElement>('.cmd-chip').forEach((c) => {
      c.disabled = disabled;
    });
  }

  function removeTrailingCursor() {
    if (!body) return;
    const last = body.lastElementChild;
    if (last && last.classList.contains('line-prompt') && last.textContent?.trim().endsWith('▍')) {
      // remove just the cursor element so the prompt stays visible without blink
      const cursor = last.querySelector('.prompt-cursor');
      cursor?.remove();
    }
  }

  function addCommandEcho(cmd: string) {
    if (!body) return;
    removeTrailingCursor();
    const div = document.createElement('div');
    div.className = 'line line-prompt';
    div.innerHTML = `<span class="prompt-prefix">~/jokeuncle</span> <span class="prompt-arrow">›</span> ${cmd}`;
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  function addPromptCaret() {
    if (!body) return;
    const div = document.createElement('div');
    div.className = 'line line-prompt';
    div.innerHTML = `<span class="prompt-prefix">~/jokeuncle</span> <span class="prompt-arrow">›</span> <span class="prompt-cursor">▍</span>`;
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  }

  async function streamLine(text: string, cls?: string) {
    if (!body) return;
    const div = document.createElement('div');
    div.className = 'line' + (cls ? ' ' + cls : '');
    body.appendChild(div);

    if (!text) {
      div.innerHTML = '&nbsp;';
      return;
    }

    // For really long lines we type in chunks for snappier feel
    const chunkSize = text.length > 60 ? 4 : 2;
    let i = 0;
    while (i < text.length) {
      div.textContent = text.slice(0, i + chunkSize);
      i += chunkSize;
      body.scrollTop = body.scrollHeight;
      await sleep(8 + Math.random() * 12);
    }
    div.textContent = text;
  }

  function clearTerminal() {
    if (!body) return;
    body.innerHTML = `
      <div class="line line-comment"># 已清屏 —— 再来一次？</div>
      <div class="line line-prompt"><span class="prompt-prefix">~/jokeuncle</span> <span class="prompt-arrow">›</span> <span class="prompt-cursor">▍</span></div>
    `;
  }

  async function runCommand(cmd: string) {
    if (isRunning || !body) return;

    if (cmd === '__clear') {
      clearTerminal();
      return;
    }

    isRunning = true;
    setChipsDisabled(true);

    addCommandEcho(cmd);

    // Small "thinking" pause
    await sleep(180 + Math.random() * 200);

    const lines = responses[cmd];
    if (!lines) {
      await streamLine(`zsh: command not found: ${cmd.split(' ')[0]}`, 'line-error');
    } else {
      for (const line of lines) {
        await streamLine(line.text, line.cls);
        // Slight beat between non-empty lines
        if (line.text) await sleep(40 + Math.random() * 80);
      }
    }

    await sleep(200);
    addPromptCaret();

    isRunning = false;
    setChipsDisabled(false);
  }

  chips?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const chip = target.closest<HTMLButtonElement>('.cmd-chip');
    if (!chip || chip.disabled) return;
    const cmd = chip.dataset.cmd;
    if (!cmd) return;
    runCommand(cmd);
  });
</script>
