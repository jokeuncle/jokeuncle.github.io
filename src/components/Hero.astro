---
// Hero Component - 3D floating background with typewriter effect
import BgText from '@/components/BgText.astro';

const roles = ['AI 工程师', 'AI-Native Builder', '系统设计者', '范式实践者'];

const transformerText =
  "The Transformer is a deep learning architecture introduced by Vaswani et al. in 2017 in the seminal paper Attention Is All You Need. It replaces recurrence and convolution with a pure self-attention mechanism, enabling massive parallelism and long-range dependency modeling that earlier RNNs and LSTMs struggled to capture. The canonical model stacks an encoder and a decoder, each composed of identical layers built from two sublayers — multi-head self-attention and a position-wise feed-forward network — wrapped by residual connections and layer normalization. Because attention is permutation-invariant, positional information is injected through sinusoidal positional encodings or learned embeddings so the model can reason about token order. Scaled dot-product attention computes softmax(QK^T / √d_k) V, where the scaling factor stabilizes gradients for large key dimensions. Multi-head attention projects queries, keys, and values into several subspaces in parallel, letting the model attend to different relational patterns simultaneously — syntactic, semantic, coreferential, positional — before concatenating and projecting the heads back. The decoder mirrors the encoder but adds a masked self-attention layer that prevents tokens from attending to future positions during autoregressive generation, plus an encoder-decoder cross-attention that conditions output on the source sequence. Modern descendants specialize this blueprint: GPT collapses to a decoder-only stack and trains with next-token prediction; BERT uses an encoder-only stack with masked-language-model and next-sentence-prediction objectives; T5 keeps the full encoder-decoder and frames every problem as text-to-text; Vision Transformers (ViT) split images into patch tokens; Whisper, AudioLM, and MusicGen apply the same machinery to spectrograms; AlphaFold leverages it for protein structure. Scaling laws by Kaplan, Hoffmann, and others showed that loss falls predictably as parameters, data, and compute grow together, motivating the leap from BERT-base at 110M to GPT-3 at 175B and beyond. Efficiency innovations — FlashAttention's IO-aware kernels, rotary positional embeddings (RoPE), grouped-query and multi-query attention, sparse and sliding-window attention, mixture-of-experts layers, KV caching, speculative decoding — have together pushed context windows past one million tokens while keeping latency tractable. Today the Transformer is the foundational substrate of modern artificial intelligence — language, vision, audio, code, robotics, multimodal reasoning, and agentic systems all converge on the same essential building block: attention, residuals, normalization, and feed-forward projection, stacked deep and trained at scale.";
---

<section class="hero" id="home">
  <!-- Background Effects -->
  <div class="hero-bg">
    <div class="three-bg" id="three-bg" aria-hidden="true"></div>
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="gradient-orb orb-3"></div>
    <div class="grid-overlay"></div>
    <BgText text={transformerText} duration={9} opacity={1} />
  </div>
  
  <!-- Content -->
  <div class="hero-content container">
    <div class="hero-badge fade-up">
      <span class="badge-dot"></span>
      <span>开放合作中</span>
    </div>
    
    <h1 class="hero-title fade-up stagger-1">
      Hi, I'm <span class="gradient-text">Lei</span>
      <span class="wave">👋</span>
    </h1>
    
    <div class="hero-subtitle fade-up stagger-2">
      <span class="typewriter-prefix">我是</span>
      <span class="typewriter" id="typewriter" data-roles={JSON.stringify(roles)}></span>
      <span class="cursor">|</span>
    </div>
    
    <p class="hero-desc fade-up stagger-3">
      热爱用代码构建优雅的数字体验，专注于现代 Web 技术与创意交互设计。
      <br />
      让每一个像素都充满意义。
    </p>
    
    <div class="hero-cta fade-up stagger-4">
      <a href="#projects" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
          <polyline points="10 17 15 12 10 7"/>
          <line x1="15" y1="12" x2="3" y2="12"/>
        </svg>
        查看作品
      </a>
      <a href="#contact" class="btn btn-secondary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        联系我
      </a>
    </div>
    
    <div class="hero-stats fade-up stagger-5">
      <div class="stat">
        <span class="stat-value">10+</span>
        <span class="stat-label">年开发经验</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">50+</span>
        <span class="stat-label">完成项目</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">∞</span>
        <span class="stat-label">学习热情</span>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <div class="mouse">
      <div class="wheel"></div>
    </div>
    <span>向下滚动</span>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    /* Top reserves space for the fixed header; bottom reserves space for the
       scroll indicator so it never overlaps hero-stats */
    padding-top: 5rem;
    padding-bottom: 7rem;
  }
  
  /* Background Effects */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(900px 700px at 50% 40%, rgba(99, 102, 241, 0.10), transparent 60%),
      radial-gradient(700px 600px at 70% 55%, rgba(34, 211, 238, 0.08), transparent 60%);
    mix-blend-mode: screen;
    opacity: 0.9;
  }
  
  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    animation: float 8s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.4) 0%, transparent 70%);
    top: -200px;
    right: -100px;
    animation-delay: 0s;
  }
  
  .orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, transparent 70%);
    bottom: -100px;
    left: -100px;
    animation-delay: -3s;
  }
  
  .orb-3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.25) 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -5s;
  }
  
  .three-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.9;
    filter: saturate(1.1) contrast(1.05);
    transform: translateZ(0);
  }

  .three-bg canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }
  
  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
  }

  /* Transformer prose backdrop with a sweeping scan-light highlight */
  .transformer-text {
    position: absolute;
    inset: 0;
    /* Center the paragraph vertically in the hero so it sits behind the
       content area, not pinned to the top */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(3rem, 8vh, 6rem) clamp(1.5rem, 6vw, 5rem);
    overflow: hidden;
    pointer-events: none;
    user-select: none;
    /* Soft radial fade so the text feels like an ambient layer, not a wall */
    mask-image: radial-gradient(ellipse at 50% 50%, black 0%, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 50%, black 0%, black 40%, transparent 80%);
    z-index: 1;
  }

  .transformer-text p {
    /* Override global `p { max-width: 65ch }` so the backdrop fills the hero */
    max-width: none;
    width: 100%;
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: clamp(0.7rem, 0.95vw, 0.95rem);
    line-height: 1.85;
    letter-spacing: 0.01em;
    text-align: justify;
    margin: 0;
    hyphens: auto;
    /* The gradient itself paints both the dim base text AND the bright scan band.
       Stops outside the band stay at the dim base color so characters always have
       a faint readable hue; the bright stripe of cyan/indigo sweeps across. */
    background-image: linear-gradient(
      105deg,
      rgba(148, 163, 184, 0.10) 0%,
      rgba(148, 163, 184, 0.10) 38%,
      rgba(99, 102, 241, 0.55) 44%,
      rgba(34, 211, 238, 1) 50%,
      rgba(236, 72, 153, 0.7) 56%,
      rgba(148, 163, 184, 0.10) 62%,
      rgba(148, 163, 184, 0.10) 100%
    );
    background-size: 240% 100%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    /* Soft glow so the bright stripe pops without the dim base getting smeared */
    filter: drop-shadow(0 0 6px rgba(34, 211, 238, 0.12));
    animation: transformer-scan 9s linear infinite;
  }

  /* Inline children inherit color:transparent from <p>, but text-fill-color
     doesn't inherit by default — set it explicitly so the parent's clipped
     gradient shows through em/code/sup/sub glyphs. */
  .transformer-text em,
  .transformer-text code,
  .transformer-text sup,
  .transformer-text sub {
    -webkit-text-fill-color: transparent;
  }

  .transformer-text em {
    font-style: italic;
  }

  .transformer-text code {
    font-family: inherit;
    font-size: 0.95em;
  }

  @keyframes transformer-scan {
    0% {
      background-position: 140% 0;
    }
    100% {
      background-position: -140% 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .transformer-text p {
      animation: none;
      background-position: 0 0;
    }
  }

  @media (max-width: 768px) {
    .transformer-text {
      padding: 2.5rem 1rem;
    }
    .transformer-text p {
      font-size: 0.7rem;
      line-height: 1.7;
    }
  }
  
  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(34, 211, 238, 0.1);
    border: 1px solid rgba(34, 211, 238, 0.2);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--accent-cyan);
    margin-bottom: 1.5rem;
  }
  
  .badge-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-cyan);
    border-radius: 50%;
    animation: pulse-glow 2s ease-in-out infinite;
  }
  
  .hero-title {
    margin-bottom: 1.5rem;
  }
  
  .wave {
    display: inline-block;
    animation: wave 2.5s ease-in-out infinite;
    transform-origin: 70% 70%;
  }
  
  @keyframes wave {
    0%, 100% { transform: rotate(0deg); }
    10% { transform: rotate(14deg); }
    20% { transform: rotate(-8deg); }
    30% { transform: rotate(14deg); }
    40% { transform: rotate(-4deg); }
    50% { transform: rotate(10deg); }
    60% { transform: rotate(0deg); }
  }
  
  .hero-subtitle {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 600;
    margin-bottom: 1.5rem;
    min-height: 3.5rem;
  }
  
  .typewriter-prefix {
    color: var(--text-secondary);
  }
  
  .typewriter {
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .cursor {
    color: var(--accent-cyan);
    animation: blink 1s step-end infinite;
  }
  
  @keyframes blink {
    50% { opacity: 0; }
  }
  
  .hero-desc {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin: 0 auto 2.5rem;
    max-width: 600px;
    line-height: 1.8;
  }
  
  .hero-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  
  .stat-value {
    font-size: 2rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .stat-label {
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border-color);
  }
  
  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-tertiary);
    font-size: 0.75rem;
    animation: float 3s ease-in-out infinite;
    z-index: 1;
    pointer-events: none;
  }
  
  .mouse {
    width: 24px;
    height: 38px;
    border: 2px solid var(--text-tertiary);
    border-radius: 12px;
    position: relative;
  }
  
  .wheel {
    width: 4px;
    height: 8px;
    background: var(--text-tertiary);
    border-radius: 2px;
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    animation: scroll 2s ease-in-out infinite;
  }
  
  @keyframes scroll {
    0%, 100% {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateX(-50%) translateY(10px);
      opacity: 0.3;
    }
  }
  
  @media (max-width: 768px) {
    .hero-stats {
      gap: 1.5rem;
    }
    
    .stat-divider {
      display: none;
    }
    
    .hero-desc br {
      display: none;
    }
  }
</style>

<script>
  // Astro hoists this module script so Vite can transform the `import 'three'`
  // and rewrite bare specifiers. Avoid `define:vars` here — it would force the
  // script to render inline, breaking module resolution in the browser.
  import * as THREE from 'three';

  // Typewriter Effect
  class Typewriter {
    constructor(element, words, wait = 3000) {
      this.element = element;
      this.words = words;
      this.wait = wait;
      this.wordIndex = 0;
      this.txt = '';
      this.isDeleting = false;
      this.type();
    }

    type() {
      const current = this.wordIndex % this.words.length;
      const fullTxt = this.words[current];

      if (this.isDeleting) {
        this.txt = fullTxt.substring(0, this.txt.length - 1);
      } else {
        this.txt = fullTxt.substring(0, this.txt.length + 1);
      }

      this.element.textContent = this.txt;

      let typeSpeed = 100;

      if (this.isDeleting) {
        typeSpeed /= 2;
      }

      if (!this.isDeleting && this.txt === fullTxt) {
        typeSpeed = this.wait;
        this.isDeleting = true;
      } else if (this.isDeleting && this.txt === '') {
        this.isDeleting = false;
        this.wordIndex++;
        typeSpeed = 500;
      }

      setTimeout(() => this.type(), typeSpeed);
    }
  }

  // Initialize typewriter — read words from a data attribute on the element
  // so we don't need `define:vars` and the script can stay a clean module.
  document.addEventListener('DOMContentLoaded', () => {
    const typewriterEl = document.getElementById('typewriter');
    if (!typewriterEl) return;
    let roles = ['AI 工程师'];
    try {
      const raw = typewriterEl.getAttribute('data-roles');
      if (raw) roles = JSON.parse(raw);
    } catch (err) {
      console.warn('[Hero] invalid data-roles', err);
    }
    new Typewriter(typewriterEl, roles, 2000);
  });

  // Three.js background
  async function initThreeBackground() {
    const container = document.getElementById('three-bg');
    if (!container) return;

    const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches;
    if (prefersReducedMotion) {
      container.style.display = 'none';
      return;
    }

    const renderer = new THREE.WebGLRenderer({
      antialias: true,
      alpha: true,
      powerPreference: 'high-performance',
    });

    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 200);
    camera.position.set(0, 0, 18);

    // Add a subtle fog for depth
    scene.fog = new THREE.Fog(0x0a0a0f, 18, 55);

    // Lights
    scene.add(new THREE.AmbientLight(0xffffff, 0.35));

    const keyLight = new THREE.DirectionalLight(0xffffff, 0.95);
    keyLight.position.set(6, 10, 14);
    scene.add(keyLight);

    const rimLight = new THREE.DirectionalLight(0x22d3ee, 0.55);
    rimLight.position.set(-10, -4, 10);
    scene.add(rimLight);

    const magentaLight = new THREE.PointLight(0xec4899, 1.1, 60);
    magentaLight.position.set(8, -6, 6);
    scene.add(magentaLight);

    // Materials
    const materialA = new THREE.MeshPhysicalMaterial({
      color: 0x6366f1,
      roughness: 0.25,
      metalness: 0.65,
      clearcoat: 1,
      clearcoatRoughness: 0.2,
      transmission: 0.05,
      thickness: 1.0,
    });

    const materialB = new THREE.MeshPhysicalMaterial({
      color: 0x22d3ee,
      roughness: 0.18,
      metalness: 0.45,
      clearcoat: 1,
      clearcoatRoughness: 0.15,
      transmission: 0.06,
      thickness: 1.0,
    });

    // Geometries
    const geometries = [
      new THREE.TorusKnotGeometry(1.6, 0.42, 220, 28),
      new THREE.IcosahedronGeometry(1.6, 1),
      new THREE.OctahedronGeometry(1.7, 0),
      new THREE.TorusGeometry(1.6, 0.36, 24, 160),
    ];

    const meshes = [];
    const count = 7;
    for (let i = 0; i < count; i++) {
      const geo = geometries[i % geometries.length];
      const mat = i % 2 === 0 ? materialA : materialB;
      const mesh = new THREE.Mesh(geo, mat);

      const angle = (i / count) * Math.PI * 2;
      const radius = 3.8 + Math.random() * 4.2;
      mesh.position.set(
        Math.cos(angle) * radius,
        (Math.random() - 0.5) * 3.6,
        Math.sin(angle) * radius - 4
      );

      const s = 0.28 + Math.random() * 0.55;
      mesh.scale.setScalar(s);
      mesh.rotation.set(
        Math.random() * Math.PI,
        Math.random() * Math.PI,
        Math.random() * Math.PI
      );

      mesh.userData = {
        rot: 0.003 + Math.random() * 0.006,
        float: 0.2 + Math.random() * 0.45,
        baseY: mesh.position.y,
      };

      scene.add(mesh);
      meshes.push(mesh);
    }

    // Resize + attach
    function resize() {
      const rect = container.getBoundingClientRect();
      const w = Math.max(1, Math.floor(rect.width));
      const h = Math.max(1, Math.floor(rect.height));
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }

    container.innerHTML = '';
    container.appendChild(renderer.domElement);
    resize();

    // Interaction
    let targetX = 0;
    let targetY = 0;

    function onPointerMove(e) {
      const rect = container.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width;
      const y = (e.clientY - rect.top) / rect.height;
      targetX = (x - 0.5) * 1.6;
      targetY = (y - 0.5) * 1.2;
    }

    window.addEventListener('pointermove', onPointerMove, { passive: true });

    // Visibility-aware loop
    let raf = 0;
    let running = true;

    const io = new IntersectionObserver(
      (entries) => {
        running = entries.some((en) => en.isIntersecting);
        if (running && !raf) loop();
      },
      { threshold: 0.01 }
    );

    io.observe(container);

    const clock = new THREE.Clock();

    function loop() {
      if (!running) {
        raf = 0;
        return;
      }

      raf = requestAnimationFrame(loop);

      const t = clock.getElapsedTime();

      camera.position.x += (targetX - camera.position.x) * 0.03;
      camera.position.y += (-targetY - camera.position.y) * 0.03;
      camera.lookAt(0, 0, 0);

      meshes.forEach((m, idx) => {
        m.rotation.x += m.userData.rot * 0.7;
        m.rotation.y += m.userData.rot;
        m.position.y = m.userData.baseY + Math.sin(t * m.userData.float + idx) * 0.25;
      });

      renderer.render(scene, camera);
    }

    // Resize observer
    const ro = new ResizeObserver(() => resize());
    ro.observe(container);

    // Start
    loop();

    // Cleanup
    window.addEventListener('pagehide', () => {
      try {
        cancelAnimationFrame(raf);
        io.disconnect();
        ro.disconnect();
        window.removeEventListener('pointermove', onPointerMove);
        renderer.dispose();
        meshes.forEach((m) => {
          m.geometry.dispose?.();
          m.material.dispose?.();
        });
      } catch {
        // ignore
      }
    });
  }

  initThreeBackground();
</script>
