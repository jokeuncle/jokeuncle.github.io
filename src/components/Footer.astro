---
// Footer Component
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-text">Lei</span>
          <span class="logo-dot"></span>
        </a>
        <p class="footer-tagline">
          构建优雅的数字体验
        </p>
      </div>
      
      <div class="footer-links">
        <a href="#home">首页</a>
        <a href="#about">关于</a>
        <a href="#skills">技能</a>
        <a href="#projects">项目</a>
        <a href="#contact">联系</a>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} Lei. 用 ❤️ 和 
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> 
        构建
      </p>
      <p class="footer-note">
        设计灵感来自优秀的开发者社区
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 4rem 0 2rem;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    position: relative;
  }
  
  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
    opacity: 0.3;
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }
  
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
  }
  
  .logo-text {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .logo-dot {
    width: 8px;
    height: 8px;
    background: var(--accent-cyan);
    border-radius: 50%;
  }
  
  .footer-tagline {
    color: var(--text-tertiary);
    font-size: 0.9375rem;
  }
  
  .footer-links {
    display: flex;
    gap: 2rem;
  }
  
  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .footer-links a:hover {
    color: var(--text-primary);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .copyright {
    color: var(--text-tertiary);
    font-size: 0.875rem;
  }
  
  .copyright a {
    color: var(--accent-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .copyright a:hover {
    color: var(--accent-cyan);
  }
  
  .footer-note {
    color: var(--text-tertiary);
    font-size: 0.8125rem;
  }
  
  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }
    
    .footer-links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem 1.5rem;
    }
    
    .footer-bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
